{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "x86cputalk",
	"patterns": [
		{
			"include": "#keywords"
		},
		{
			"include": "#strings"
		}
	],
	"repository": {
		"keywords": {
			"patterns": [{
				"name": "keyword.control.x86cputalk",
				"match": "\\b(db|dw|dd|dq|equ|section|ret|syscall|call|mov)\\b"
			}]
		},
		"strings": {
			"name": "string.quoted.double.x86cputalk",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "constant.character.escape.x86cputalk",
					"match": "\\\\."
				}
			]
		}
	},
	"scopeName": "source.x86cputalk"
}